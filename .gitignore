# =============================================================================
# .gitignore — f1_2026_predictions
#
# Sections:
#   1. Secrets & credentials      — NEVER commit these
#   2. Python environment         — uv / venv artifacts
#   3. Build & packaging          — dist, eggs, compiled extensions
#   4. Data & model artifacts     — raw/processed data, trained models
#   5. Jupyter notebooks          — checkpoints and output cells
#   6. Profiling & report outputs — sweetviz HTML, figures
#   7. Cache directories          — FastF1, pytest, ruff, mypy
#   8. IDE & OS artifacts         — VS Code, PyCharm, macOS, Windows
#   9. Logging & temp files
# =============================================================================


# =============================================================================
# 1. SECRETS & CREDENTIALS — non-negotiable
# =============================================================================
.env
.env.*
!.env.example          # .env.example is safe and must be committed

*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
credentials.json
service_account.json
*_credentials.json
*_secret*.json
secrets/


# =============================================================================
# 2. PYTHON ENVIRONMENT — uv / venv
# =============================================================================
.venv/
venv/
env/
ENV/
.python-version        # Committed via `uv python pin` — keep if team shares Python version
                       # Uncomment the line below to ignore it:
# .python-version

# uv lock file: commit uv.lock for reproducible installs across teammates.
# Uncomment to ignore if this is a library (not an application):
# uv.lock

__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Compiled C extensions (from packages with native bindings like XGBoost)
*.so
*.dll
*.dylib


# =============================================================================
# 3. BUILD & PACKAGING
# =============================================================================
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST
wheels/
pip-wheel-metadata/
share/python-wheels/


# =============================================================================
# 4. DATA & MODEL ARTIFACTS
# Rule: raw and processed data are NOT committed to git.
#       Use DVC, S3, or a shared NAS for versioned data storage.
#       Only schema definitions and sample fixtures (<1MB) belong in git.
# =============================================================================

# Raw FastF1 downloads and intermediate DataFrames
data/raw/
data/processed/
data/outputs/*
!data/outputs/models/

# Parquet, CSV, JSON data files anywhere in the project
*.parquet
*.arrow
*.feather
*.csv
*.tsv
*.json.gz
*.jsonl

# Exception: allow external metadata
!data/external/
!data/external/**/*.csv

# Exception: committed fixture / sample files for unit tests
!tests/fixtures/**/*.csv
!tests/fixtures/**/*.json
!tests/fixtures/**/*.parquet

# Exception: allow predicted CSVs in reports folder
!reports/**/*.csv

# Trained model artifacts (serialized with joblib/pickle)
models/artifacts/
*.pkl
*.pickle
*.joblib

# Exception: allow our production model
!data/outputs/models/
!data/outputs/models/*.joblib
*.h5
*.hdf5
*.pt
*.pth
*.onnx
*.cbm                  # CatBoost model format
*.bin                  # LightGBM model format
*.ubj                  # XGBoost universal binary JSON


# =============================================================================
# 5. JUPYTER NOTEBOOKS
# Commit .ipynb source. Ignore checkpoints and execution state.
# Strip output cells before committing using:
#   nbstripout (recommended) or: jupyter nbconvert --clear-output
# =============================================================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# nbconvert output
*.nbconvert.ipynb

# Temporary notebook execution artifacts
profile_default/
ipython_config.py


# =============================================================================
# 6. PROFILING & REPORT OUTPUTS
# Generated files from sweetviz, missingno, matplotlib, plotly.
# These are build artifacts — reproducible from code, not source-controlled.
# =============================================================================
reports/figures/
reports/*.html
reports/*.pdf

# sweetviz HTML reports (generated by sweetviz.analyze().show_html())
*_sweetviz_report.html
sweetviz_report.html
SWEETVIZ_REPORT.html

# matplotlib / plotly / seaborn static exports
*.png
*.jpg
*.jpeg
*.svg
*.eps
*.pdf

# Exception: allow documentation images
!images/
!images/*.png
!images/*.jpg
!images/*.jpeg
!images/*.svg

# Exception: allow report PNGs and HTMLs in reports folder
!reports/**/*.png
!reports/**/*.html



# =============================================================================
# 7. CACHE DIRECTORIES
# =============================================================================

# FastF1 caches telemetry locally — can be several GB per season
fastf1_cache/
.fastf1_cache/
cache/

# pytest
.pytest_cache/
.pytest_runtime/
.pytest_tmp/
.pytest_work/
.cache/

# ruff
.ruff_cache/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# coverage
.coverage
.coverage.*
coverage.xml
htmlcov/

# profilers
*.prof
*.lprof


# =============================================================================
# 8. IDE & OS ARTIFACTS
# =============================================================================

# VS Code — commit .vscode/settings.json and .vscode/extensions.json
# Ignore personal launch configs and workspace state
.vscode/launch.json
.vscode/*.code-workspace
.history/

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr
out/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# =============================================================================
# 9. LOGGING & TEMPORARY FILES
# =============================================================================
*.log
logs/
*.tmp
*.temp
*.swp
*.bak
*.orig
.~lock.*
scratch/

# =============================================================================
# 10. Agent-specific files
# =============================================================================
.agents/

# ===   ==========================================================================
# 11. Other files
# =============================================================================
.vscode/
.codacy.yml