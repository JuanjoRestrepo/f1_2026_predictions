# ============================================================
# F1 2026 Predictive Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── FastF1 Cache ────────────────────────────────────────────
# FastF1 caches ~500MB per season of telemetry data.
# Stored inside .cache to keep project self-contained while remaining ignored by Git.
F1_FASTF1_CACHE_DIR=.cache/fastf1

# ── Data Layer Paths (relative to project root) ─────────────
F1_DATA_RAW_DIR=data/raw
F1_DATA_PROCESSED_DIR=data/processed
F1_DATA_OUTPUTS_DIR=data/outputs
F1_DATA_EXTERNAL_DIR=data/external
F1_MODELS_DIR=models/artifacts
F1_REPORTS_DIR=reports

# ── Pipeline Parameters ─────────────────────────────────────
F1_TARGET_SEASON=2026
F1_RANDOM_SEED=42
F1_CV_N_SPLITS=5
F1_LOG_LEVEL=INFO

# ── AI (Gemini) ─────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# Gemini 3.1 Pro is the primary reasoning model for race narratives.
# Gemini 3.5 Flash is the fallback to keep automated reports publishing
# when Pro preview quota, billing, or availability blocks a run.
F1_GEMINI_API_KEY=your_gemini_api_key_here
F1_GEMINI_MODEL=gemini-3.1-pro-preview
F1_GEMINI_FALLBACK_MODEL=gemini-3.5-flash
F1_GEMINI_RETRIES=2

# ── Notification System (Gmail SMTP) ────────────────────────
# All fields are OPTIONAL. If not set, pipeline runs normally
# but skips sending email/Discord notifications.
#
# Step 1: Enable 2-Step Verification on your Google account.
# Step 2: Go to myaccount.google.com/apppasswords
# Step 3: Create an App Password named "F1 Briefings"
# Step 4: Paste the 16-char code (without spaces) below.
#
F1_GMAIL_USER=yourgmail@gmail.com
F1_GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
F1_RECIPIENT_EMAIL=recipient@example.com

# ── Notification System (Discord — optional) ─────────────────
# Create a webhook at: Server Settings → Integrations → Webhooks
# This is a secret — never commit the real URL.
F1_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
